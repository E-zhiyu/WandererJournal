<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" /> <!-- 闹钟设置权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" /> <!-- 开机监听权限 -->
    <uses-permission
        android:name="android.permission.REQUEST_INSTALL_PACKAGES"
        tools:ignore="RequestInstallPackagesPolicy" /> <!-- 安装APK权限 -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- 网络权限 -->
    <uses-permission android:name="android.permission.CAMERA" /> <!-- 相机权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" /> <!-- 通知权限 -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" /> <!-- 生物验证使用权限 -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- 声明需要交互的应用 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.SEND" /> <!-- 分享文件 -->
        </intent>
    </queries>

    <application
        android:name=".WandererJournal"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WandererJournal.Static"
        tools:targetApi="33">
        <activity
            android:name=".ui.pages.media.FullScreenMediaActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.statistics.StatisticsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.emotion.EmotionTagAddModifyActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.emotion.EmotionTagManageActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.main.settings.sub.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.WriteActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.DiaryReadActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.main.settings.sub.DataManageActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.main.settings.sub.PermissionManageActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pages.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 日记提醒广播接收器 -->
        <receiver
            android:name=".automation.broadcast.DiaryAlarmReceiver"
            android:enabled="true"
            android:exported="false"
            android:label="触发检查当天是否有日记的广播接收器">
            <intent-filter>
                <action android:name="com.wanderer.journal.DiaryCheckReceiver" />
            </intent-filter>
        </receiver>

        <!-- 开机广播接收器 -->
        <receiver
            android:name=".automation.broadcast.BootReceiver"
            android:enabled="true"
            android:exported="false"
            android:label="开机完毕的监听器，用于自动安排第二天0点的预算重置闹钟">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- 兼容旧版本 Android 需要添加以下权限 -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>

</manifest>