<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 标题栏样式 -->
    <style name="ToolBarStyle" parent="Widget.Material3.Toolbar.OnSurface">
        <item name="android:backgroundTint">?attr/colorSurface</item>
        <item name="navigationIconTint">?attr/colorPrimary</item>
        <item name="navigationIcon">@drawable/outline_arrow_back_ios_new_24</item>
        <item name="contentInsetStart">10dp</item>
        <item name="titleTextAppearance">?attr/textAppearanceHeadlineSmall</item>
    </style>

    <!-- 底部导航栏样式 -->
    <style name="NaviStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="itemTextColor">@color/bottom_navigation_selector</item>
        <item name="itemIconTint">@color/bottom_navigation_selector</item>
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="itemActiveIndicatorStyle">@style/NaviActiveIndicator</item>
    </style>

    <!-- 底部导航栏指示器颜色 -->
    <style name="NaviActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorSecondaryContainer</item>
    </style>

    <!-- 卡片样式基类 -->
    <style name="CardStyleBase" parent="Widget.Material3.CardView.Elevated">
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- 中等圆角卡片容器 -->
    <style name="MediumRadiusCardStyle" parent="CardStyleBase">
        <item name="cardCornerRadius">20dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <!-- 直角卡片容器 -->
    <style name="RightAngleCardStyle" parent="CardStyleBase">
        <item name="cardCornerRadius">0dp</item>
    </style>

    <!-- 图片视图样式 -->
    <style name="ImageViewStyle">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="tint">?attr/colorPrimary</item>
        <item name="android:padding">10dp</item>
    </style>

    <!-- “添加”浮动按钮样式 -->
    <style name="AddFloatingActionBtnStyle" parent="Widget.Material3.FloatingActionButton.Tertiary">
        <item name="android:src">@drawable/outline_add_24</item>
        <item name="android:layout_marginEnd">20dp</item>
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <!-- 开关样式 -->
    <style name="SwitchBtnStyle" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="android:drawablePadding">5dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">10dp</item>
    </style>

    <!-- 图标按钮样式 -->
    <style name="ImageButtonStyle" parent="Widget.AppCompat.ImageButton">
        <item name="tint">?attr/colorPrimary</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">@drawable/ripple_circle</item>
    </style>

    <!-- 普通按钮样式 -->
    <style name="CommonBtnStyle" parent="Widget.Material3Expressive.Button">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="layout_goneMarginStart">5dp</item>
        <item name="layout_goneMarginEnd">5dp</item>
        <item name="layout_goneMarginTop">5dp</item>
        <item name="layout_goneMarginBottom">5dp</item>
        <item name="iconGravity">textStart</item>
    </style>

    <!-- 透明背景按钮样式 -->
    <style name="TextBtnStyle" parent="Widget.Material3Expressive.Button.TextButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="iconPadding">2dp</item>
    </style>

    <!-- 仅保留边框的按钮样式 -->
    <style name="OutlinedBtnStyle" parent="Widget.Material3Expressive.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">1dp</item>
        <item name="iconGravity">textStart</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
    </style>

    <!-- 圆形图片视图样式 -->
    <style name="RoundedImageViewStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 普通文本框布局样式 -->
    <style name="CommonTextInputLayoutStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="endIconDrawable">@drawable/baseline_clear_24</item>
        <item name="endIconMode">clear_text</item>
    </style>

    <!-- 下拉菜单式文本框布局样式 -->
    <style name="DropdownMenuTextInputLayoutStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu">
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <!-- 需要用户输入文本的文本框样式 -->
    <style name="UserInputEditTextStyle" parent="Widget.Material3.TextInputEditText.OutlinedBox.Dense">
        <item name="android:inputType">text</item>
    </style>

    <!-- 自动填充文本框样式 -->
    <style name="UneditableAutoCompleteTextViewStyle" parent="Widget.Material3.AutoCompleteTextView.OutlinedBox.Dense">
        <item name="android:inputType">none</item>
        <item name="maxLines">1</item>
    </style>

    <!-- 可点击的文本框样式 -->
    <style name="ClickableTextViewStyle">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingBottom">15dp</item>
        <item name="android:textSize">17sp</item>
        <item name="android:drawablePadding">15dp</item>
        <item name="android:paddingStart">20dp</item>
    </style>
</resources>